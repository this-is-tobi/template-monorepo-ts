{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    { "title": "API Overview", "url": "/d/api-overview/api-overview", "type": "link", "icon": "dashboard" },
    { "title": "Prisma / Database", "url": "/d/prisma-database/prisma-database", "type": "link", "icon": "database" }
  ],
  "panels": [
    {
      "type": "row",
      "title": "Span Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Total Spans / sec",
      "description": "Rate of all trace spans (all types)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traces_span_metrics_calls_total[5m]))",
          "legendFormat": "spans/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null },
              { "color": "blue", "value": 10 },
              { "color": "green", "value": 100 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "HTTP Spans / sec",
      "description": "Rate of HTTP request spans",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traces_span_metrics_calls_total{span_name=\"request\"}[5m]))",
          "legendFormat": "http/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Prisma Spans / sec",
      "description": "Rate of all Prisma-related spans",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traces_span_metrics_calls_total{span_name=~\"prisma:.*\"}[5m]))",
          "legendFormat": "prisma/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Error Spans / sec",
      "description": "Rate of spans with error status",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traces_span_metrics_calls_total{status_code=\"STATUS_CODE_ERROR\"}[5m])) or vector(0)",
          "legendFormat": "errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Span Rate Breakdown",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Spans by Name",
      "description": "Span creation rate by span name (request, prisma:client:operation, fastify hooks, etc.)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traces_span_metrics_calls_total[5m])) by (span_name)",
          "legendFormat": "{{ span_name }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 0, "stacking": { "mode": "normal" } },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Spans by Status",
      "description": "Span creation rate grouped by status (OK, ERROR, UNSET)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traces_span_metrics_calls_total[5m])) by (status_code)",
          "legendFormat": "{{ status_code }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*OK.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*ERROR.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*UNSET.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "type": "row",
      "title": "Span Duration",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Duration by Span Name (p95)",
      "description": "95th percentile duration per span name",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(traces_span_metrics_duration_milliseconds_bucket[5m])) by (le, span_name))",
          "legendFormat": "{{ span_name }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Span Duration (p50 / p95 / p99)",
      "description": "HTTP request span duration percentiles from trace spans",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(traces_span_metrics_duration_milliseconds_bucket{span_name=\"request\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(traces_span_metrics_duration_milliseconds_bucket{span_name=\"request\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(traces_span_metrics_duration_milliseconds_bucket{span_name=\"request\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 5, "lineWidth": 2, "gradientMode": "scheme" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "type": "row",
      "title": "Top Spans",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Top Span Names by Count",
      "description": "Most frequent span names in the selected time range",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(20, sum(increase(traces_span_metrics_calls_total[$__range])) by (span_name))",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": { "span_name": "Span Name", "Value": "Count" },
            "excludeByName": { "Time": true }
          }
        },
        {
          "id": "sortBy",
          "options": { "sort": [{ "field": "Count", "desc": true }] }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Count" }, "properties": [{ "id": "unit", "value": "short" }, { "id": "decimals", "value": 0 }] }
        ]
      }
    },
    {
      "type": "table",
      "title": "Slowest Span Names (p99)",
      "description": "Span names with highest p99 duration",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(20, histogram_quantile(0.99, sum(rate(traces_span_metrics_duration_milliseconds_bucket[$__range])) by (le, span_name)))",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": { "span_name": "Span Name", "Value": "p99 (ms)" },
            "excludeByName": { "Time": true }
          }
        },
        {
          "id": "sortBy",
          "options": { "sort": [{ "field": "p99 (ms)", "desc": true }] }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "p99 (ms)" }, "properties": [{ "id": "unit", "value": "s" }, { "id": "decimals", "value": 3 }] }
        ]
      }
    },
    {
      "type": "row",
      "title": "HTTP by Route (from spans)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Span Rate by HTTP Route",
      "description": "Trace-derived request rate per route (from spanmetrics)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traces_span_metrics_calls_total{span_name=\"request\", http_route!=\"\"}[5m])) by (http_route, http_request_method)",
          "legendFormat": "{{ http_request_method }} {{ http_route }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Span Duration by HTTP Route (p95)",
      "description": "95th percentile span duration per HTTP route (from spanmetrics)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(traces_span_metrics_duration_milliseconds_bucket{span_name=\"request\", http_route!=\"\"}[5m])) by (le, http_route))",
          "legendFormat": "{{ http_route }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Trace Search",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "All Traces",
      "description": "Search and browse all traces from Tempo",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 42 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceqlSearch",
          "limit": 30,
          "spss": 3,
          "tableType": "traces",
          "filters": [
            { "id": "service-name", "tag": "service.name", "operator": "=", "value": ["api"], "valueType": "string", "scope": "resource" }
          ]
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "traceID" },
            "properties": [
              { "id": "links", "value": [{ "title": "View trace", "url": "/explore?left=%7B%22datasource%22:%22tempo%22,%22queries%22:%5B%7B%22refId%22:%22A%22,%22queryType%22:%22traceql%22,%22query%22:%22${__value.raw}%22%7D%5D%7D", "targetBlank": true }] }
            ]
          }
        ]
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["traces", "spans", "otel"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Traces Explorer",
  "uid": "traces-explorer",
  "version": 1
}
