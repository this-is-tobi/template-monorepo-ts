# Copy to .env.docker for use with docker-compose.
# Variables are used differently depending on the Docker target:
#   - dev:  VITE_* vars are read by the Vite dev server
#   - prod: API_URL is injected at container startup via envsubst in entrypoint.sh

# Dev (Vite dev server inside Docker) ———————————————————————————————
# VITE_API_URL is the URL the browser uses to reach the API (host-side port).
# Include the API base path in the URL (e.g. /api).
VITE_API_URL=http://localhost:8081/api
# API_PROXY_TARGET is the URL the Vite proxy uses to reach the API (Docker network).
API_PROXY_TARGET=http://api:8081

# Prod (nginx + entrypoint.sh) ————————————————————————————
# API_URL is substituted into config.js by envsubst at container startup.
# Include the API base path (e.g. http://api:8080/api). For a dedicated
# API domain without prefix, use the origin only.
API_URL=http://api:8080/api
# APP_VERSION is injected at container startup (set by CI/CD during release).
APP_VERSION=dev
