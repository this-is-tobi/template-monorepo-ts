API__DOMAIN=localhost:8081
API__HOST=localhost
API__PORT=8081
API__VERSION=dev
DB__URL=postgresql://admin:admin@localhost:5432/template-monorepo-ts?schema=public
DB__PRISMA_SCHEMA_PATH=./prisma/schema.prisma
DOC__URL=http://localhost:8082

# Auth
AUTH__SECRET=change-me-in-production-use-256-bit-random
AUTH__BASE_URL=http://localhost:8081
AUTH__TRUSTED_ORIGINS=http://localhost:3000
AUTH__REDIS_URL=redis://localhost:6379

# Keycloak (optional - when running Keycloak locally via Docker)
KEYCLOAK__ENABLED=false
KEYCLOAK__CLIENT_ID=template-monorepo-ts
KEYCLOAK__CLIENT_SECRET=change-me
KEYCLOAK__ISSUER=http://localhost:8084/realms/template-monorepo-ts

# Initial admin user (optional - created on first startup if set)
ADMIN__EMAIL=admin@example.com
ADMIN__PASSWORD=admin

# Modules (toggle features on/off)
MODULES__AUTH=true
