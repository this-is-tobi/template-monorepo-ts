/// Key-value settings store for web application configuration (e.g. theme).
/// Each row is a unique key with a JSON value, created/updated with timestamps.
model WebSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("web_setting")
}
