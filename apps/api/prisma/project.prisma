// ---------------------------------------------------------------------------
// project.prisma — application domain model for the projects resource
// ---------------------------------------------------------------------------

model Project {
  id             String   @id @default(uuid())
  name           String
  description    String?
  ownerId        String
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([ownerId])
  @@index([organizationId])
}
