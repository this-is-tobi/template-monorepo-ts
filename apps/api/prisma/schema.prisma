datasource db {
  provider = "postgresql"
}

generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  engineType    = "client"
  runtime       = "bun"
  compilerBuild = "small"
}

model User {
  id        String  @id @default(uuid())
  firstname String
  lastname  String
  email     String  @unique
  bio       String?

  @@map("Users")
}
