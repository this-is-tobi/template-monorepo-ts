// ---------------------------------------------------------------------------
// schema.prisma — datasource + generator config only
//
// Models are split by domain in:
//   auth.prisma   — authentication + org models (BetterAuth plugins)
//   audit.prisma  — audit log (opt-in audit module)
// ---------------------------------------------------------------------------

datasource db {
  provider = "postgresql"
}

generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  engineType    = "client"
  runtime       = "bun"
  compilerBuild = "small"
}
