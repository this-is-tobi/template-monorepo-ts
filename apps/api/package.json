{
  "name": "@template-monorepo-ts/api",
  "type": "module",
  "version": "0.1.0",
  "license": "ISC",
  "scripts": {
    "build": "bun run compile && bun run build:bun && bun run build:prisma-config",
    "build:bun": "NODE_ENV=production bun build ./src/server.ts --minify --outdir ./dist --target bun --external '@prisma/client/runtime/*'",
    "build:node": "NODE_ENV=production bun build ./src/server.ts --minify --outdir ./dist --target node --external '@prisma/client/runtime/*'",
    "build:binary": "bun build ./src/server.ts --minify --compile --outfile ./dist/bin",
    "build:prisma-config": "bun build ./prisma.config.ts --outfile ./dist/prisma.config.js --target node --external 'prisma/*' --external '@prisma/*' --external 'node:*'",
    "build:clean": "rimraf ./dist ./tsconfig.tsbuildinfo",
    "compile": "tsc -p ./tsconfig.build.json",
    "db:deploy": "bunx prisma migrate deploy",
    "db:generate": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate dev",
    "db:reset": "bunx prisma migrate reset",
    "db:check": "bunx prisma migrate diff --from-config-datasource --to-schema ./prisma --exit-code",
    "db:auth:generate": "bun x @better-auth/cli generate --config ./src/modules/auth/auth.ts --output ./prisma/auth.prisma -y",
    "db:wrapper": "sh ./scripts/migrate-db.sh",
    "db:seed-demo": "NODE_ENV=development bun run ./scripts/seed-demo.ts",
    "db:seed-perf": "NODE_ENV=development bun run ./scripts/seed-perf.ts",
    "dev": "NODE_ENV=development bun run --hot ./src/server.ts",
    "docker:build": "docker build --file ./Dockerfile --tag template-monorepo-ts/api --target prod ../..",
    "docker:run": "docker run --publish 8081:8080 --rm template-monorepo-ts/api",
    "format": "eslint ./src --fix",
    "lint": "eslint ./src",
    "start": "bun run ./dist/server.js",
    "test": "vitest run",
    "test:ui": "vitest --watch --ui",
    "test:cov": "vitest run --coverage",
    "test:e2e": "echo 'Check local changes for turbo cache...'"
  },
  "dependencies": {
    "@better-auth/api-key": "catalog:",
    "@better-auth/redis-storage": "catalog:",
    "@fastify/cookie": "^11.1.2",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/otel": "^0.20.1",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0",
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-prometheus": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/instrumentation": "^7.8.0",
    "@template-monorepo-ts/logger": "workspace:*",
    "@template-monorepo-ts/shared": "workspace:*",
    "better-auth": "catalog:",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@prisma/config": "^7.8.0",
    "@prisma/migrate": "^7.8.0",
    "@template-monorepo-ts/eslint-config": "workspace:*",
    "@template-monorepo-ts/test-utils": "workspace:*",
    "@template-monorepo-ts/ts-config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/ioredis": "^5.0.0",
    "@types/node": "catalog:",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-istanbul": "catalog:",
    "@vitest/ui": "catalog:",
    "pino-pretty": "catalog:",
    "prisma": "^7.8.0",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vitest-mock-extended": "^4.0.0"
  }
}
