{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node"],
    "declaration": false,
    "declarationDir": null,
    "emitDeclarationOnly": false,
    "noEmit": true
  },
  "exclude": [
    "./node_modules",
    "./dist",
    "./types",
    "./vitest.config.ts",
    "./vitest-init.ts",
    "./prisma.config.ts",
    "./scripts",
    "**/*.spec.ts",
    "**/__mocks__/**"
  ]
}
