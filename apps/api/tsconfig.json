{
  "extends": [
    "@template-monorepo-ts/ts-config/tsconfig.base.json"
  ],
  "compilerOptions": {
    "rootDir": "./src",
    "paths": {
      "~/*": ["./src/*"]
    },
    "types": ["vitest/globals", "node"],
    "allowImportingTsExtensions": false,
    "noEmit": true
  },
  "include": [
    "./**/*.ts"
  ],
  "exclude": [
    "./node_modules",
    "./dist",
    "./types",
    "./scripts",
    "./vitest.config.ts",
    "./vitest-init.ts",
    "./prisma.config.ts"
  ]
}
