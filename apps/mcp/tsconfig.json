{
  "extends": "@template-monorepo-ts/ts-config/tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "paths": {
      "~/*": ["./src/*"]
    },
    "types": ["bun"],
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationDir": "./types",
    "emitDeclarationOnly": true,
    "noEmit": false
  },
  "include": ["./src"]
}
