{
  "name": "@template-monorepo-ts/mcp",
  "type": "module",
  "version": "0.1.0",
  "description": "MCP server for template-monorepo-ts API",
  "license": "ISC",
  "main": "dist/index.js",
  "types": "types/index.d.ts",
  "bin": {
    "tmts-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "bun run compile && bun run build:node && bun run build:binary",
    "build:node": "bun build ./src/index.ts --outdir ./dist --target node",
    "build:binary": "bun build --compile ./src/index.ts --outfile ./bin/tmts-mcp",
    "build:clean": "rimraf ./dist ./types ./bin ./tsconfig.tsbuildinfo",
    "compile": "tsc -p ./tsconfig.build.json",
    "format": "eslint ./src --fix",
    "lint": "eslint ./src",
    "test": "vitest run",
    "test:ui": "vitest --watch --ui",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@template-monorepo-ts/logger": "workspace:*",
    "@template-monorepo-ts/shared": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@template-monorepo-ts/eslint-config": "workspace:*",
    "@template-monorepo-ts/ts-config": "workspace:*",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@vitest/coverage-istanbul": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
