# Docker Compose development environment variables
# Copy this file to .env.docker and adjust values as needed.
# WARNING: These are development-only defaults — never use in production.

# --- API ---
AUTH__SECRET=dev-secret-change-in-production-use-256-bit
AUTH__BASE_URL=http://localhost:8081
AUTH__TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8082
AUTH__REDIS_URL=redis://redis:6379
KEYCLOAK__ENABLED=true
KEYCLOAK__CLIENT_ID=template-monorepo-ts
KEYCLOAK__CLIENT_SECRET=change-me
KEYCLOAK__ISSUER=http://keycloak:8080/realms/template-monorepo-ts
KEYCLOAK__PUBLIC_URL=http://localhost:8084/realms/template-monorepo-ts
KEYCLOAK__MAP_ROLES=true
KEYCLOAK__MAP_GROUPS=true
ADMIN__EMAIL=admin@example.com
ADMIN__PASSWORD=admin
MODULES__AUTH=true

# --- PostgreSQL ---
POSTGRES_DB=template-monorepo-ts
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

# --- Keycloak DB ---
KC_POSTGRES_DB=keycloak
KC_POSTGRES_USER=keycloak
KC_POSTGRES_PASSWORD=keycloak

# --- Keycloak ---
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak
KC_BOOTSTRAP_ADMIN_USERNAME=admin@example.com
KC_BOOTSTRAP_ADMIN_PASSWORD=admin

# --- Migrations ---
DB__URL=postgresql://admin:admin@db:5432/template-monorepo-ts?schema=public
