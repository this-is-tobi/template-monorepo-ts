{
  // visuals
  "window.autoDetectColorScheme": true,
  "editor.fontLigatures": "'ss01', 'ss02', 'ss03', 'ss06', 'zero'",
  "editor.cursorBlinking": "phase",
  "editor.wordWrap": "on",
  "editor.tabSize": 2,
  "editor.minimap.enabled": false,
  "editor.formatOnSave": true,
  "search.exclude": {
    "**/.git": true,
    "**/.turbo": true,
    "**/.eslintcache": true,
    "**/dist/**": true,
    "**/out/**": true,
    "**/logs": true,
    "**/node_modules": true,
    "**/bun.lock": true,
    "**/coverage/**": true,
    "**/playwright-report/**": true,
    "**/test-results/**": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.turbo/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/coverage/**": true,
    "**/playwright-report/**": true,
    "**/test-results/**": true
  },
  // general
  "editor.unicodeHighlight.invisibleCharacters": false,
  "workbench.startupEditor": "none",
  // yaml — disable validation globally, re-enable only for plain yaml files
  // (prevents Red Hat YAML extension from validating Helm templates)
  "yaml.validate": false,
  "yaml.schemas": {
    "https://json.schemastore.org/chart.json": "**/helm/Chart.yaml"
  },
  "redhat.telemetry.enabled": false,
  "[yaml]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[helm-template]": {
    "editor.formatOnSave": false
  },
  // git
  "git.autofetch": true,
  "git.untrackedChanges": "separate",
  // github
  "githubPullRequests.pullBranch": "never",
  // eslint
  "editor.codeActionsOnSave": {
    "source.fixAll": "never",
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "never"
  },
  "eslint.quiet": false,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue",
    "html",
    "markdown",
    "json",
    "jsonc",
    "yaml",
    "toml",
    "xml",
    "gql",
    "graphql",
    "astro",
    "svelte",
    "css",
    "less",
    "scss",
    "pcss",
    "postcss"
  ],
  // stylelint — disable built-in validation to avoid false positives on Tailwind/UnoCSS directives
  "css.validate": false,
  "less.validate": false,
  "scss.validate": false,
  // languages
  "[javascript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "javascript.preferences.quoteStyle": "single",
  "javascript.preferences.importModuleSpecifierEnding": "js",
  "javascript.suggest.completeJSDocs": true,
  "javascript.suggest.jsdoc.generateReturns": true,
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "typescript.preferences.quoteStyle": "single",
  "typescript.preferences.importModuleSpecifierEnding": "js",
  "typescript.suggest.completeJSDocs": true,
  "typescript.suggest.jsdoc.generateReturns": true,
  "[json]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[markdown]": {
    "editor.quickSuggestions": {
      "other": true,
      "comments": true,
      "strings": true
    },
    "editor.formatOnPaste": true,
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  },
  // conventional commits
  "conventionalCommits.showNewVersionNotes": false,
  // kubernetes
  "vs-kubernetes": {
    "vs-kubernetes.crd-code-completion": "enabled"
  },
  "vscode-kubernetes.log-viewer.follow": true,
  "vscode-kubernetes.log-viewer.timestamp": false,
  "vscode-kubernetes.log-viewer.since": -1,
  "vscode-kubernetes.log-viewer.tail": -1,
  "vscode-kubernetes.log-viewer.destination": "Webview",
  "vscode-kubernetes.log-viewer.wrap": true
}
