{
  "name": "@template-monorepo-ts/logger",
  "type": "module",
  "version": "0.1.0",
  "description": "Shared Pino-based structured logger for all apps and packages",
  "license": "ISC",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "types/index.d.ts",
  "scripts": {
    "build": "bun run compile && bun run build:node",
    "build:node": "bun build ./src/index.ts --outdir ./dist --target node --external pino --external pino-pretty --external @opentelemetry/api",
    "build:clean": "rimraf ./dist ./types ./tsconfig.tsbuildinfo",
    "compile": "tsc -p ./tsconfig.build.json",
    "format": "eslint ./src --fix",
    "lint": "eslint ./src",
    "test": "vitest run",
    "test:ui": "vitest --watch --ui",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@opentelemetry/api": "catalog:",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@template-monorepo-ts/eslint-config": "workspace:*",
    "@template-monorepo-ts/ts-config": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "@vitest/ui": "catalog:",
    "pino-pretty": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
